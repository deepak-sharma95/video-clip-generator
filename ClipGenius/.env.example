# ============================================
# ClipGenius - Environment Configuration
# Copy this file to .env and update values
# ============================================

# --- General ---
APP_NAME=ClipGenius
DEBUG=true
LOG_LEVEL=INFO

# --- Paths ---
TEMP_DIR=./temp
OUTPUT_DIR=./output

# --- Clip Settings ---
DEFAULT_CLIP_DURATION=18
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=20
MAX_CLIPS=3

# --- Download Settings ---
MAX_VIDEO_DURATION=7200     # 2 hours in seconds
PREFERRED_RESOLUTION=1080
